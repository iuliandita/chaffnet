{
  "name": "chaffnet-mcp",
  "version": "0.1.0",
  "description": "Official MCP server for the chaffnet content classification API",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iuliandita/chaffnet.git",
    "directory": "packages/chaffnet-mcp"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "chaffnet-mcp": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "chaffnet": "0.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "bun test test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
